# Database Configuration
# Copy this file to .env and update with your AWS RDS credentials

# AWS RDS PostgreSQL Connection Details
DB_HOST=your-rds-instance.region.rds.amazonaws.com
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_rds_password
DB_PORT=5432
DB_SSLMODE=verify-full
DB_SSLROOTCERT=certs/global-bundle.pem
DB_CONNECT_TIMEOUT=10

# Example for AWS RDS:
# DB_HOST=campaign-db.c1abc2defgh.us-east-1.rds.amazonaws.com
# DB_NAME=campaign_management
# DB_USER=admin
# DB_PASSWORD=YourSecurePassword123
# DB_PORT=5432
# DB_SSLMODE=verify-full
# DB_SSLROOTCERT=certs/global-bundle.pem
# DB_CONNECT_TIMEOUT=10
